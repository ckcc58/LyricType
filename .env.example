PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=

# Auth.js / Google OAuth
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Google AI Studio のAPIキー（Gemini用）
GOOGLE_API_KEY=

# GCP Console で作成したAPIキー（YouTube Data API v3用）
# console.cloud.google.com → APIとサービス → 認証情報 → APIキー作成
YOUTUBE_API_KEY=

# Upstash Redis（レート制限用）
# https://upstash.com でRedis DBを作成し、REST APIのURL/Tokenをコピーする
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
